# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard
SUPABASE_SERVICE_KEY=your-service-role-key

# Database (from Supabase project settings → Database → Connection string)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# Supabase Storage
SUPABASE_STORAGE_BUCKET=workflow-files

# Redis (Railway Redis plugin auto-injects REDIS_URL; use redis://localhost:6379 for local dev)
REDIS_URL=redis://localhost:6379

# Anthropic (for OCR)
ANTHROPIC_API_KEY=sk-ant-xxx

# App
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173
