# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard
SUPABASE_SERVICE_KEY=your-service-role-key

# Database (from Supabase project settings → Database → Connection string)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=workflowapp-files
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Upstash Redis
UPSTASH_REDIS_URL=rediss://default:token@host.upstash.io:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# App
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173
